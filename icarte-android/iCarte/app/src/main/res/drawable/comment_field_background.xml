<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle" >

    <!-- view background color -->
    <solid android:color="@color/no_color" >
    </solid>

    <!-- If you want to add some padding -->
    <padding
        android:right="@dimen/nopadding"
        android:left="@dimen/nopadding">
    </padding>

    <!-- view border color and width -->
    <stroke
        android:width="@dimen/item_border_width"
        android:color="@color/no_color">
    </stroke>

    <!-- Here is the corner radius -->
    <corners android:radius="@dimen/item_corner_radius" >
    </corners>

</shape>