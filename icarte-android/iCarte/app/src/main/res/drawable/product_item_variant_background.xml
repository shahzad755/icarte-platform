<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle" >

    <!-- view background color -->
    <solid android:color="#f69c55" >
    </solid>

    <padding
        android:right="@dimen/item_variant_padding_right_left"
        android:left="@dimen/item_variant_padding_right_left"
        android:top="@dimen/item_variant_padding_top_bottom"
        android:bottom="@dimen/item_variant_padding_top_bottom">
    </padding>

    <!-- view border color and width -->
    <stroke
        android:width="@dimen/item_border_width"
        android:color="#f58532" >
    </stroke>

    <!-- Here is the corner radius -->
    <corners android:radius="@dimen/item_corner_radius" >
    </corners>

</shape>