<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="icarte.armedialab.com.icarte.ui.ItemImageSliderActivity"
    android:background="@color/cartview_activity_background">

    <com.facebook.drawee.view.SimpleDraweeView
        android:id="@+id/slidingImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:actualImageScaleType="fitXY"
        app:placeholderImage="@drawable/img_placeholder"
        />

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/close"
        android:background="?android:attr/selectableItemBackground"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginEnd="@dimen/activity_horizontal_margin_half"
        android:layout_marginTop="@dimen/activity_horizontal_margin_half"
        android:text="@string/close" />

    <com.ctrlplusz.anytextview.AnyTextView
        app:typeface="Bariol_Regular.otf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/txtItemImageSliderTitle"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:textSize="28sp"
        android:textColor="@color/primary_text"
        android:maxLines="3"
        android:paddingBottom="@dimen/item_padding_top_bottom"
        android:gravity="center"
        android:background="@color/list_background"
        android:visibility="invisible"/>
</RelativeLayout>
