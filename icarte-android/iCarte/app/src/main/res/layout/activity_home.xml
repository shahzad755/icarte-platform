            <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/ico_home_event"
                        android:src="@drawable/ico_event_calendar"
                android:layout_alignParentEnd="false"
                android:layout_alignParentBottom="false"
                android:layout_toEndOf="@+id/ico_home_menu"
                android:layout_marginStart="20dp"
                android:background="@color/no_color"
                android:elevation="@dimen/default_elevation"
                 />

            <ImageButton
                        android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                        android:id="@+id/ico_home_rating"
                        android:src="@drawable/ico_home_rating"
                android:layout_alignParentBottom="false"
                android:layout_toEndOf="@+id/ico_home_event"
                android:layout_marginStart="20dp"
                android:background="@color/no_color"
                android:elevation="@dimen/default_elevation"
                />

            <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/ico_home_aboutus"
                        android:src="@drawable/ico_location"
                android:layout_toEndOf="@+id/ico_home_rating"
                android:layout_alignParentBottom="false"
                android:layout_marginStart="20dp"
                android:background="@color/no_color"
                android:elevation="@dimen/default_elevation"
                />

            <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/icon_home_contactus"
                        android:src="@drawable/ico_contact_us"
                android:layout_toEndOf="@+id/ico_home_aboutus"
                android:layout_alignParentBottom="false"
                android:layout_marginStart="20dp"
                android:background="@color/no_color"
                android:elevation="@dimen/default_elevation"
                />
    -->
    <android.support.design.widget.FloatingActionButton
        android:id="@+id/btnCallWaiter"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ico_call_waitor_white_32x32"
        android:layout_gravity="bottom|end"
        app:elevation="8dp"
        app:pressedTranslationZ="12dp"
        app:backgroundTint="@color/primary"
        app:rippleColor="@color/fab_action_color"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="@dimen/fab_btn_end_margin"
        android:layout_marginEnd="@dimen/fab_btn_end_margin"
        app:fabSize="normal"
        />

</RelativeLayout>
