<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="icarte.armedialab.com.icarte.ui.SplashScreenProgressBarActivity"
    android:background="@drawable/splash_screen"
    android:id="@+id/splash_container">

<!--
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/splash_image"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:src="@drawable/splash_screen"
        android:scaleType="fitXY" />
-->
    <me.fichardu.circleprogress.CircleProgress
        android:id="@+id/progress"
        android:layout_width="75dp"
        android:layout_height="75dp"
        app:color1="@android:color/holo_red_light"
        app:color2="@android:color/holo_green_light"
        app:color3="@android:color/holo_blue_light"
        android:visibility="invisible"
        android:layout_gravity="center_horizontal"
        android:layout_above="@+id/logo"
        android:layout_centerHorizontal="true" />

    <ImageView
        android:layout_width="248dp"
        android:layout_height="85dp"
        android:id="@+id/logo"
        android:layout_alignParentEnd="false"
        android:src="@drawable/logo"
        android:layout_centerInParent="true" />

    <com.ctrlplusz.anytextview.AnyTextView
        android:id="@+id/txtConnectionError"
        app:typeface="Lobster-Regular.ttf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:visibility="gone"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/red"
        android:layout_above="@+id/containerBtnRetry"
        android:layout_marginBottom="@dimen/activity_horizontal_margin_half"
        android:layout_marginEnd="@dimen/activity_horizontal_margin"
        android:layout_marginStart="@dimen/activity_horizontal_margin"/>

    <com.andexert.library.RippleView
        android:id="@+id/containerBtnRetry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:elevation="8dp"
        android:focusable="true"
        android:clickable="true"
        app:rv_color="@color/white"
        app:rv_type="simpleRipple"
        app:rv_alpha="150"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="@dimen/activity_vertical_margin_double"
        >
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/btnRetry"
                android:src="@drawable/ico_retry_white"
                android:visibility="gone"
                android:background="@drawable/cart_button_background_selector"
                />
    </com.andexert.library.RippleView>
</RelativeLayout>
