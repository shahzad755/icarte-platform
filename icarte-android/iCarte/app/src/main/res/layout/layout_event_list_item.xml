<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="@dimen/activity_horizontal_margin_half"
    android:paddingRight="@dimen/activity_horizontal_margin_half"
    android:paddingTop="@dimen/activity_vertical_margin_half"
    android:paddingBottom="@dimen/activity_vertical_margin_half">

    <android.support.v7.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/item_corner_radius"
        android:layout_marginTop="9dp"
        android:layout_marginLeft="9dp"
        android:layout_marginRight="9dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="9dp"
        android:clickable="true"
        android:foreground="?android:attr/selectableItemBackground">
            <LinearLayout
                android:id="@+id/mainLayoutContactUs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_below="@+id/toolbar"
                android:layout_marginTop="@dimen/activity_vertical_margin_half"
                android:baselineAligned="false">

                <RelativeLayout
                    android:id="@+id/eventContainer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.1"
                    android:gravity="end"
                    android:paddingTop="@dimen/activity_vertical_margin_half">

                    <com.ctrlplusz.anytextview.AnyTextView
                        android:id="@+id/txtCalDay"
                        app:typeface="NoticiaText-Regular.ttf"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="32sp"
                        android:paddingTop="@dimen/activity_horizontal_margin_half"
                        android:textColor="@color/primary_dark"
                        android:background="@drawable/calendar_64x64"
                        android:textStyle="bold" />

                    <com.ctrlplusz.anytextview.AnyTextView
                        android:id="@+id/txtCalMonth"
                        app:typeface="NoticiaText-Regular.ttf"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="22sp"
                        android:textColor="@color/secondary_text"
                        android:paddingStart="@dimen/item_padding_top_bottom"
                        android:paddingEnd="@dimen/item_padding_top_bottom"
                        android:textStyle="bold"
                        android:layout_below="@id/txtCalDay"/>

                    <com.ctrlplusz.anytextview.AnyTextView
                        android:id="@+id/txtCalYear"
                        app:typeface="NoticiaText-Regular.ttf"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:textColor="@color/secondary_text"
                        android:paddingStart="@dimen/item_padding_top_bottom"
                        android:paddingEnd="@dimen/item_padding_top_bottom"
                        android:textStyle="bold"
                        android:layout_below="@id/txtCalMonth"/>
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/eventDetailContainer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.9"
                    android:paddingStart="@dimen/activity_horizontal_margin_half"
                    android:paddingEnd="@dimen/activity_horizontal_margin_half"
                    android:paddingBottom="@dimen/activity_horizontal_margin_half"
                    >
                    <com.android.volley.ui.NetworkImageViewPlus
                        android:id="@+id/imgEvent"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:scaleType="centerCrop"
                        app:default_image="@drawable/bg_def_event_dubai_skyline"
                        app:error_image="@drawable/bg_def_event_dubai_skyline"
                        android:focusable="true"
                        android:clickable="true"
                        />
                    <com.ctrlplusz.anytextview.AnyTextView
                        android:id="@+id/txtEventName"
                        app:typeface="NoticiaText-Regular.ttf"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="@color/list_background"
                        android:gravity="center"
                        android:textSize="22sp"
                        android:textColor="@color/primary_text"
                        android:paddingTop="@dimen/item_padding_top_bottom"
                        android:paddingBottom="@dimen/item_padding_top_bottom"
                        android:paddingStart="@dimen/item_padding_top_bottom"
                        android:paddingEnd="@dimen/item_padding_top_bottom"
                        android:textStyle="bold"
                        android:layout_alignBottom="@+id/imgEvent"
                        android:layout_alignParentStart="true" />

                    <com.ctrlplusz.anytextview.AnyTextView
                        android:id="@+id/txtEventDescription"
                        app:typeface="NoticiaText-Regular.ttf"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:textSize="18sp"
                        android:textColor="@color/secondary_text"
                        android:paddingTop="@dimen/item_padding_top_bottom"
                        android:paddingStart="@dimen/item_padding_left_right"
                        android:paddingEnd="@dimen/item_padding_left_right"
                        android:textStyle="bold"
                        android:layout_below="@id/txtEventName"/>

                </RelativeLayout>
            </LinearLayout>
        </android.support.v7.widget.CardView>
</LinearLayout>