<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="@dimen/activity_vertical_margin_half"
    android:paddingEnd="@dimen/item_padding_top_bottom"
    android:paddingStart="@dimen/item_padding_top_bottom">

    <com.ctrlplusz.anytextview.AnyTextView
        android:id="@+id/txtBranchName"
        app:typeface="NoticiaText-Regular.ttf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textColor="@color/primary_text"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="@dimen/item_padding_top_bottom"
        />

    <com.ctrlplusz.anytextview.AnyTextView
        android:id="@+id/txtAddress"
        app:typeface="NoticiaText-Regular.ttf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/primary_text"
        android:layout_below="@+id/txtBranchName"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="@dimen/item_padding_top_bottom"
        />

    <ImageView
        android:id="@+id/imgTel"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ico_call"
        android:contentDescription="@string/help_delete_item_from_cart"
        android:layout_marginBottom="@dimen/item_padding_top_bottom"
        android:layout_below="@+id/txtAddress" />

    <com.ctrlplusz.anytextview.AnyTextView
        android:id="@+id/txtTel"
        app:typeface="NoticiaText-Regular.ttf"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="18sp"
        android:textColor="@color/primary_text"
        android:paddingStart="@dimen/activity_horizontal_margin_half"
        android:paddingEnd="@dimen/item_padding_left_right"
        android:layout_alignBottom="@+id/imgTel"
        android:layout_toEndOf="@+id/imgTel" />

    <ImageView
        android:id="@+id/imgEmail"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:src="@drawable/ico_email"
        android:contentDescription="@string/help_delete_item_from_cart"
        android:layout_marginBottom="@dimen/item_padding_top_bottom"
        android:layout_below="@+id/imgTel" />

    <com.ctrlplusz.anytextview.AnyTextView
        android:id="@+id/txtEmail"
        app:typeface="NoticiaText-Regular.ttf"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/primary_text"
        android:paddingStart="@dimen/item_padding_left_right"
        android:paddingEnd="@dimen/item_padding_left_right"
        android:paddingTop="20dp"
        android:layout_below="@+id/txtTel"
        android:layout_toEndOf="@+id/imgEmail" />

    <ImageView
        android:id="@+id/imgLocation"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:src="@drawable/ico_branch_location"
        android:contentDescription="@string/help_delete_item_from_cart"
        android:layout_marginBottom="@dimen/item_padding_top_bottom"
        android:layout_below="@+id/imgEmail" />

    <com.ctrlplusz.anytextview.AnyTextView
        android:id="@+id/txtLocation"
        app:typeface="NoticiaText-Regular.ttf"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/primary_text"
        android:text="@string/title_click_to_location"
        android:paddingStart="@dimen/item_padding_left_right"
        android:paddingEnd="@dimen/item_padding_left_right"
        android:paddingTop="@dimen/activity_vertical_margin"
        android:layout_below="@+id/txtEmail"
        android:layout_toEndOf="@+id/imgLocation" />

</RelativeLayout>