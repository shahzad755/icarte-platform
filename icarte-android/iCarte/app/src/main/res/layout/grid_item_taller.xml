<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="fill_parent"
    android:layout_height="@dimen/grid_item_taller_height"
    android:clipChildren="false"
    android:minHeight="@dimen/grid_item_taller_height"
    android:padding="@dimen/grid_item_spacing">

    <com.android.volley.ui.NetworkImageViewPlus
        android:id="@+id/imgCategory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:default_image="@drawable/img_placeholder"
        app:error_image="@drawable/logo"
        android:adjustViewBounds="true" />

    <TextView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:id="@+id/txtCategoryTitle"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:textSize="15sp"
        android:textAlignment="center"
        android:background="@color/list_background"
        android:textColor="@color/list_item_title"
        android:gravity="center|bottom"
        android:maxLines="2"
        android:padding="20dp"
        android:textStyle="bold" />
</RelativeLayout>