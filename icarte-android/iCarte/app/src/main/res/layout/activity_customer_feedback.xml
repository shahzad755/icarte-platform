<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutFeedbackMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="@dimen/activity_horizontal_margin_half"
    android:paddingRight="@dimen/activity_horizontal_margin_half"
    android:paddingTop="@dimen/activity_vertical_margin_half"
    android:paddingBottom="@dimen/activity_vertical_margin_half"
    android:background="@drawable/splash_screen"
    tools:context="icarte.armedialab.com.icarte.ui.CustomerFeedbackActivity">
    <include layout="@layout/common_nav_home_layout" />

    <me.fichardu.circleprogress.CircleProgress
        android:id="@+id/progressViewOnFeedback"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:color1="@android:color/holo_red_light"
        app:color2="@android:color/holo_green_light"
        app:color3="@android:color/holo_blue_light"
        android:visibility="invisible"
        android:layout_gravity="center_horizontal"
        android:layout_centerInParent="true" />

    <!-- Here dynamic layout out will be added -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/layoutContainerCommonNavHomeHeader">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:id="@+id/layoutContainerFeedback">
            <LinearLayout
                android:id="@+id/layoutFeedbackCustomerDetails"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/item_padding_top_bottom"
                android:paddingStart="@dimen/item_padding_top_bottom"
                android:paddingEnd="@dimen/item_padding_top_bottom"
                >

                <com.ctrlplusz.anytextview.AnyTextView
                    android:id="@+id/txtFeedackCustomerFName"
                    app:typeface="NoticiaText-BoldItalic.ttf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/primary_text"
                    android:layout_gravity="center_vertical"
                    android:gravity="start"
                    android:text="@string/label_txt_customer_fname"/>
                <com.rengwuxian.materialedittext.MaterialEditText
                    android:id="@+id/editFeedbackCustomerFName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:met_maxCharacters="100"
                    app:met_primaryColor="@color/feedback_text"
                    app:met_textColor="@color/feedback_text"
                    app:met_textColorHint="@color/feedback_text_hint"
                    app:met_underlineColor="@color/feedback_text_line"
                    app:met_errorColor="@color/feedback_text_line"
                    />

                <com.ctrlplusz.anytextview.AnyTextView
                    android:id="@+id/txtFeedbackCustomerLName"
                    app:typeface="NoticiaText-BoldItalic.ttf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/primary_text"
                    android:layout_gravity="center_vertical"
                    android:gravity="start"
                    android:text="@string/label_txt_customer_lname"/>
                <com.rengwuxian.materialedittext.MaterialEditText
                    android:id="@+id/editFeedbackCustomerLName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:met_maxCharacters="100"
                    app:met_primaryColor="@color/feedback_text"
                    app:met_textColor="@color/feedback_text"
                    app:met_textColorHint="@color/feedback_text_hint"
                    app:met_underlineColor="@color/feedback_text_line"
                    app:met_errorColor="@color/feedback_text_line"
                    />

                <com.ctrlplusz.anytextview.AnyTextView
                    android:id="@+id/txtFeedbackCustomerContact"
                    app:typeface="NoticiaText-BoldItalic.ttf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/primary_text"
                    android:layout_gravity="center_vertical"
                    android:gravity="start"
                    android:text="@string/label_txt_customer_contact"/>
                <com.rengwuxian.materialedittext.MaterialEditText
                    android:id="@+id/editFeedbackCustomerContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    app:met_maxCharacters="10"
                    app:met_primaryColor="@color/feedback_text"
                    app:met_textColor="@color/feedback_text"
                    app:met_textColorHint="@color/feedback_text_hint"
                    app:met_underlineColor="@color/feedback_text_line"
                    app:met_errorColor="@color/feedback_text_line"
                    />

                <com.ctrlplusz.anytextview.AnyTextView
                    android:id="@+id/txtFeedbackCustomerEmail"
                    app:typeface="NoticiaText-BoldItalic.ttf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/primary_text"
                    android:layout_gravity="center_vertical"
                    android:gravity="start"
                    android:text="@string/label_txt_customer_email"/>
                <com.rengwuxian.materialedittext.MaterialEditText
                    android:id="@+id/editFeedbackCustomerEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    app:met_maxCharacters="100"
                    app:met_primaryColor="@color/feedback_text"
                    app:met_textColor="@color/feedback_text"
                    app:met_textColorHint="@color/feedback_text_hint"
                    app:met_underlineColor="@color/feedback_text_line"
                    app:met_errorColor="@color/feedback_text_line"
                    />


            </LinearLayout>


        </LinearLayout>
    </ScrollView>

    <android.support.design.widget.FloatingActionButton
        android:id="@+id/btnSubmitFeedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ico_paper_plane_white"
        android:layout_gravity="bottom|end"
        app:elevation="8dp"
        app:pressedTranslationZ="12dp"
        app:backgroundTint="@color/primary"
        app:rippleColor="@color/fab_action_color"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="@dimen/fab_btn_bottom_margin"
        android:layout_marginEnd="@dimen/fab_btn_end_margin"
        />

</RelativeLayout>
